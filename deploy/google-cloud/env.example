# Copy file ini menjadi env.sh lalu isi sesuai akun Google Cloud kamu.

export PROJECT_ID="isi-project-id-google-cloud"
export ZONE="asia-southeast2-a"
export REGION="asia-southeast2"
export VM_NAME="airnav-yolo-backend"
export MACHINE_TYPE="e2-standard-4"
export BOOT_DISK_SIZE="40GB"
export REPO_URL="https://github.com/iqbalusman/airnav-iot-dashboard.git"
export VM_USER="$USER"

# Kamera lokal tetap IP lokal. VM Google Cloud bisa membaca IP ini hanya jika
# jaringan kamera sudah tersambung lewat Tailscale/subnet router/VPN.
export CAMERA_SOURCE="http://192.168.1.51/stream"

# Domain backend YOLO. Buat DNS A record ke external IP VM.
export YOLO_DOMAIN="yolo.airnavgorontalo.com"

# Opsional. Jika diisi, startup script akan login Tailscale otomatis.
# Buat auth key di Tailscale Admin Console.
export TAILSCALE_AUTH_KEY=""
